Algoritmo RESGISTRO_DE_ESTUDIANTE
	
	Definir nombre,carrera Como Caracter
	Definir edad, semestre Como Real
	
	Escribir "Ingrese su nombre:"
	Leer nombre
	
	Escribir "Ingrese su edad:"
	Leer edad
	
	Escribir "Ingrese el nombre de su carrera"
	Leer carrera

	Escribir "Ingrese el semestre que esta cursando:"
	Leer semestre
	
	Escribir "Su nombre es:",nombre
	Escribir "Su edad es:",edad
	Escribir "Su carrera es:",carrera
	Escribir "El semestre que cursa es:",semestre
	
FinAlgoritmo
