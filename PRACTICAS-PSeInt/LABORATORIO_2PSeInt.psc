Algoritmo COMPRA_EN_TIENDA
	
	Definir nombre Como Caracter
	Definir cantidad,resultado Como Real
	
	Escribir "Ingrese su nombre:"
	Leer nombre
	
	Escribir "Ingrese la cantidad que esta comprando:"
	Leer cantidad
	
	resultado <-cantidad*8
	
	Escribir"El monto a cancelar por los ",cantidad," productos es de: ",resultado," bs"
	
FinAlgoritmo
